<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.RekamMedisController"
            stylesheets="@style.css">

    <!-- HEADER -->

    <top>

        <VBox alignment="CENTER"
              spacing="15"
              styleClass="top-panel">

            <padding>
                <Insets top="20"
                        right="20"
                        bottom="10"
                        left="20"/>
            </padding>

            <Label text="DATA REKAM MEDIS"
                   styleClass="title"/>

        </VBox>

    </top>

    <!-- CONTENT -->

    <center>

        <VBox spacing="20">

            <padding>
                <Insets top="20"
                        right="25"
                        bottom="20"
                        left="25"/>
            </padding>

            <!-- Toolbar -->

            <HBox spacing="15"
                  alignment="CENTER">

                <Button text="➕"
                        onAction="#handleTambah"
                        styleClass="btn-tambah"/>

                <Button text="✏"
                        onAction="#handleEdit"
                        styleClass="btn-edit"/>

                <Button text="🗑"
                        onAction="#handleHapus"
                        styleClass="btn-hapus"/>

                <Button text="🔄"
                        onAction="#loadData"
                        styleClass="btn-refresh"/>

                <TextField fx:id="txtCari"
                           promptText="Cari rekam medis..."
                           prefWidth="180"/>

                <Button text="🔍"
                        onAction="#handleCari"
                        styleClass="btn-cari"/>

                <Button text="❌"
                        onAction="#handleClose"
                        styleClass="btn-close"/>

            </HBox>

            <!-- TABLE -->
            <VBox spacing="15"
      styleClass="card"
      VBox.vgrow="ALWAYS">

    <padding>
        <Insets top="20"
                right="20"
                bottom="20"
                left="20"/>
    </padding>

    <Label text="Data Rekam Medis"
           styleClass="subtitle"/>

    <TableView fx:id="tableRekamMedis"
               VBox.vgrow="ALWAYS">

        <columns>

            <TableColumn fx:id="colId"
                         text="ID"/>

            <TableColumn fx:id="colPasien"
                         text="Pasien"/>

            <TableColumn fx:id="colTanggal"
                         text="Tanggal"/>

            <TableColumn fx:id="colDiagnosa"
                         text="Diagnosa"/>

            <TableColumn fx:id="colRingkasan"
                         text="Ringkasan"/>

        </columns>

    </TableView>

    </VBox>
    
    </VBox>
            
    </center>

</BorderPane>