<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.FormResepObatController"
            stylesheets="@style.css">

    <!-- ===================== -->
    <!-- HEADER -->
    <!-- ===================== -->

    <top>

        <VBox alignment="CENTER"
              spacing="15"
              styleClass="top-panel">

            <padding>
                <Insets top="20"
                        right="20"
                        bottom="10"
                        left="20"/>
            </padding>

            <Label text="FORM RESEP OBAT"
                   styleClass="title"/>

        </VBox>

    </top>

    <!-- ===================== -->
    <!-- FORM -->
    <!-- ===================== -->

    <center>

        <VBox alignment="CENTER"
              spacing="25">

            <padding>
                <Insets top="20"
                        right="30"
                        bottom="20"
                        left="30"/>
            </padding>

            <GridPane alignment="CENTER"
                      hgap="20"
                      vgap="18">

                <columnConstraints>
                    <ColumnConstraints minWidth="170"/>
                    <ColumnConstraints minWidth="230"/>
                    <ColumnConstraints minWidth="170"/>
                    <ColumnConstraints minWidth="230"/>
                </columnConstraints>

                <!-- Baris 1 -->

                <Label text="ID Resep"/>

                <TextField fx:id="txtId"
                           editable="false"
                           prefWidth="220"
                           GridPane.columnIndex="1"/>

                <Label text="Pilih Pemeriksaan"
                       GridPane.columnIndex="2"/>

                <ComboBox fx:id="cbPemeriksaan"
                          prefWidth="220"
                          GridPane.columnIndex="3"/>

                <!-- Baris 2 -->

                <Label text="Pilih Obat"
                       GridPane.rowIndex="1"/>

                <ComboBox fx:id="cbObat"
                          prefWidth="220"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="1"/>

                <Label text="Jumlah"
                       GridPane.columnIndex="2"
                       GridPane.rowIndex="1"/>

                <TextField fx:id="txtJumlah"
                           prefWidth="220"
                           GridPane.columnIndex="3"
                           GridPane.rowIndex="1"/>

                <!-- Baris 3 -->

                <Label text="Dosis"
                       GridPane.rowIndex="2"/>

                <ComboBox fx:id="cbDosis"
                           prefWidth="220"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="2"/>

                <!-- Baris 4 -->

                <Label text="Keterangan"
                       GridPane.rowIndex="3"/>

                <TextArea fx:id="txtKeterangan"
                          prefWidth="460"
                          prefHeight="100"
                          wrapText="true"
                          GridPane.columnIndex="1"
                          GridPane.columnSpan="3"
                          GridPane.rowIndex="3"/>

            </GridPane>

            <!-- Tombol -->

            <HBox alignment="CENTER"
                  spacing="20">

                <Button text="💾 Simpan"
                        onAction="#handleSimpan"
                        styleClass="btn-save-modern"/>

                <Button text="✖ Batal"
                        onAction="#handleBatal"
                        styleClass="btn-cancel-modern"/>

            </HBox>

        </VBox>

    </center>

</BorderPane>