<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.LaporanController">

    <top>

        <VBox alignment="CENTER" spacing="8">

            <padding>
                <Insets top="20" bottom="20"/>
            </padding>

            <Label text="LAPORAN KLINIK"
                   style="-fx-font-size:30px;
                          -fx-font-weight:bold;"/>

            <Label text="Ringkasan statistik Smart Clinic"/>

        </VBox>

    </top>

    <center>

        <VBox spacing="20">

            <padding>
                <Insets top="20"
                        right="20"
                        bottom="20"
                        left="20"/>
            </padding>

            <!-- CARD -->

            <HBox spacing="15">

                <VBox prefWidth="220"
                      style="-fx-background-color:#2563eb;
                             -fx-background-radius:12;
                             -fx-padding:15;">

                    <Label text="👤 Total Pasien"
                           style="-fx-text-fill:white;
                                  -fx-font-weight:bold;"/>

                    <Label fx:id="lblPasien"
                           text="0"
                           style="-fx-font-size:28;
                                  -fx-text-fill:white;
                                  -fx-font-weight:bold;"/>

                </VBox>

                <VBox prefWidth="220"
                      style="-fx-background-color:#22c55e;
                             -fx-background-radius:12;
                             -fx-padding:15;">

                    <Label text="🩺 Total Dokter"
                           style="-fx-text-fill:white;
                                  -fx-font-weight:bold;"/>

                    <Label fx:id="lblDokter"
                           text="0"
                           style="-fx-font-size:28;
                                  -fx-text-fill:white;
                                  -fx-font-weight:bold;"/>

                </VBox>

                <VBox prefWidth="220"
                      style="-fx-background-color:#f59e0b;
                             -fx-background-radius:12;
                             -fx-padding:15;">

                    <Label text="📋 Pemeriksaan"
                           style="-fx-text-fill:white;
                                  -fx-font-weight:bold;"/>

                    <Label fx:id="lblPeriksa"
                           text="0"
                           style="-fx-font-size:28;
                                  -fx-text-fill:white;
                                  -fx-font-weight:bold;"/>

                </VBox>

                <VBox prefWidth="220"
                      style="-fx-background-color:#ef4444;
                             -fx-background-radius:12;
                             -fx-padding:15;">

                    <Label text="🧠 Prediksi"
                           style="-fx-text-fill:white;
                                  -fx-font-weight:bold;"/>

                    <Label fx:id="lblPrediksi"
                           text="0"
                           style="-fx-font-size:28;
                                  -fx-text-fill:white;
                                  -fx-font-weight:bold;"/>

                </VBox>

            </HBox>

            <!-- TABEL -->

            <Label text="Riwayat Prediksi"
                   style="-fx-font-size:18;
                          -fx-font-weight:bold;"/>

            <TableView fx:id="tablePrediksi"
                       prefHeight="420">

                <columns>

                    <TableColumn fx:id="colId"
                                 text="ID"
                                 prefWidth="70"/>

                    <TableColumn fx:id="colGlucose"
                                 text="Glucose"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colBMI"
                                 text="BMI"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colAge"
                                 text="Age"
                                 prefWidth="100"/>

                    <TableColumn fx:id="colHasil"
                                 text="Hasil Prediksi"
                                 prefWidth="250"/>

                    <TableColumn fx:id="colProb"
                                 text="Probabilitas"
                                 prefWidth="150"/>

                </columns>

            </TableView>

            <HBox alignment="CENTER_RIGHT"
                  spacing="10">

                <Button text="Refresh"
                        onAction="#handleRefresh"/>

                <Button text="Tutup"
                        onAction="#handleClose"/>

            </HBox>

        </VBox>

    </center>

</BorderPane>