<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.FormPemeriksaanController"
            stylesheets="@style.css">

    <top>

        <VBox alignment="CENTER"
              spacing="15"
              styleClass="top-panel">

            <padding>
                <Insets top="20"
                        right="20"
                        bottom="10"
                        left="20"/>
            </padding>

            <Label text="FORM PEMERIKSAAN"
                   styleClass="title"/>

        </VBox>

    </top>

    <center>

        <VBox alignment="CENTER"
              spacing="25">

            <padding>
                <Insets top="20"
                        right="30"
                        bottom="20"
                        left="30"/>
            </padding>

            <GridPane alignment="CENTER"
                      hgap="20"
                      vgap="18">

                <columnConstraints>
                    <ColumnConstraints minWidth="170"/>
                    <ColumnConstraints minWidth="230"/>
                    <ColumnConstraints minWidth="170"/>
                    <ColumnConstraints minWidth="230"/>
                </columnConstraints>

                <!-- Baris 1 -->

                <Label text="ID Pemeriksaan"/>

                <TextField fx:id="txtId"
                           editable="false"
                           prefWidth="220"
                           GridPane.columnIndex="1"/>

                <Label text="Pilih Pendaftaran"
                       GridPane.columnIndex="2"/>

                <ComboBox fx:id="cbPendaftaran"
                          prefWidth="220"
                          GridPane.columnIndex="3"/>

                <!-- Baris 2 -->

                <Label text="Tanggal Periksa"
                       GridPane.rowIndex="1"/>

                <DatePicker fx:id="dpTanggal"
                            prefWidth="220"
                            GridPane.columnIndex="1"
                            GridPane.rowIndex="1"/>

                <Label text="Diagnosa"
                       GridPane.columnIndex="2"
                       GridPane.rowIndex="1"/>

                <TextField fx:id="txtDiagnosa"
                           prefWidth="220"
                           GridPane.columnIndex="3"
                           GridPane.rowIndex="1"/>

                <!-- Baris 3 -->

                <Label text="Tekanan Darah"
                       GridPane.rowIndex="2"/>

                <TextField fx:id="txtTekanan"
                           prefWidth="220"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="2"/>

                <Label text="Gula Darah"
                       GridPane.columnIndex="2"
                       GridPane.rowIndex="2"/>

                <TextField fx:id="txtGula"
                           prefWidth="220"
                           GridPane.columnIndex="3"
                           GridPane.rowIndex="2"/>

                <!-- Baris 4 -->

                <Label text="Suhu Tubuh (°C)"
                       GridPane.rowIndex="3"/>

                <TextField fx:id="txtSuhu"
                           prefWidth="220"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="3"/>

                <Label text="Berat Badan (kg)"
                       GridPane.columnIndex="2"
                       GridPane.rowIndex="3"/>

                <TextField fx:id="txtBerat"
                           prefWidth="220"
                           GridPane.columnIndex="3"
                           GridPane.rowIndex="3"/>

                <!-- Baris 5 -->

                <Label text="Hasil Prediksi ML"
                       GridPane.rowIndex="4"/>

                <TextField fx:id="txtPrediksi"
                           editable="false"
                           prefWidth="220"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="4"/>

                <Label text="Tingkat Risiko"
                       GridPane.columnIndex="2"
                       GridPane.rowIndex="4"/>

                <TextField fx:id="txtRisiko"
                           editable="false"
                           prefWidth="220"
                           GridPane.columnIndex="3"
                           GridPane.rowIndex="4"/>

                <!-- Baris 6 -->

                <Label text="Catatan Dokter"
                       GridPane.rowIndex="5"/>

                <TextArea fx:id="txtCatatan"
                          prefWidth="460"
                          prefHeight="100"
                          wrapText="true"
                          GridPane.columnIndex="1"
                          GridPane.columnSpan="3"
                          GridPane.rowIndex="5"/>

            </GridPane>

            <HBox alignment="CENTER"
                  spacing="20">

                <Button text="💾 Simpan"
                        onAction="#handleSimpan"
                        styleClass="btn-save-modern"/>

                <Button text="✖ Batal"
                        onAction="#handleBatal"
                        styleClass="btn-cancel-modern"/>

            </HBox>

        </VBox>

    </center>

</BorderPane>