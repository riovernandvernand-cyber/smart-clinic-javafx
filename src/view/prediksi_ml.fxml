<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.PrediksiMLController"
            stylesheets="@style.css">

    <!-- ================= HEADER ================= -->

    <top>

        <VBox alignment="CENTER"
              spacing="10"
              styleClass="top-panel">

            <padding>
                <Insets top="20"
                        right="20"
                        bottom="15"
                        left="20"/>
            </padding>

            <Label text="PREDIKSI RISIKO DIABETES"
                   styleClass="title"/>

            <Label text="Masukkan data medis pasien untuk memprediksi risiko diabetes."
                   styleClass="subtitle"/>

        </VBox>

    </top>

    <!-- ================= CONTENT ================= -->

    <center>

        <VBox spacing="20">

            <padding>
                <Insets top="20"
                        right="25"
                        bottom="20"
                        left="25"/>
            </padding>

            <VBox spacing="20"
                  styleClass="card">

                <padding>
                    <Insets top="20"
                            right="20"
                            bottom="20"
                            left="20"/>
                </padding>

                <GridPane hgap="20"
                          vgap="18">

                    <columnConstraints>
                        <ColumnConstraints minWidth="180"/>
                        <ColumnConstraints minWidth="220"/>
                        <ColumnConstraints minWidth="180"/>
                        <ColumnConstraints minWidth="220"/>
                    </columnConstraints>

                    <!-- BARIS 1 -->

                    <Label text="Pregnancies"/>

                    <TextField fx:id="txtPregnancies"
                               promptText="0"
                               GridPane.columnIndex="1"/>

                    <Label text="Glucose"
                           GridPane.columnIndex="2"/>

                    <TextField fx:id="txtGlucose"
                               promptText="120"
                               GridPane.columnIndex="3"/>

                    <!-- BARIS 2 -->

                    <Label text="Blood Pressure"
                           GridPane.rowIndex="1"/>

                    <TextField fx:id="txtBloodPressure"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="1"/>

                    <Label text="Skin Thickness"
                           GridPane.columnIndex="2"
                           GridPane.rowIndex="1"/>

                    <TextField fx:id="txtSkinThickness"
                               GridPane.columnIndex="3"
                               GridPane.rowIndex="1"/>

                    <!-- BARIS 3 -->

                    <Label text="Insulin"
                           GridPane.rowIndex="2"/>

                    <TextField fx:id="txtInsulin"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="2"/>

                    <Label text="BMI"
                           GridPane.columnIndex="2"
                           GridPane.rowIndex="2"/>

                    <TextField fx:id="txtBMI"
                               GridPane.columnIndex="3"
                               GridPane.rowIndex="2"/>

                    <!-- BARIS 4 -->

                    <Label text="Diabetes Pedigree Function"
                           GridPane.rowIndex="3"/>

                    <TextField fx:id="txtDPF"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="3"/>

                    <Label text="Age"
                           GridPane.columnIndex="2"
                           GridPane.rowIndex="3"/>

                    <TextField fx:id="txtAge"
                               GridPane.columnIndex="3"
                               GridPane.rowIndex="3"/>

                </GridPane>

                <!-- BUTTON -->

                <HBox alignment="CENTER"
                      spacing="20">

                    <Button text="🔍 Prediksi Sekarang"
                            onAction="#handlePrediksi"
                            styleClass="btn-save-modern"/>

                    <Button text="🔄 Reset"
                            onAction="#handleReset"
                            styleClass="btn-refresh"/>

                    <Button text="❌ Tutup"
                            onAction="#handleClose"
                            styleClass="btn-close"/>

                </HBox>

            </VBox>

            <!-- HASIL -->

            <VBox spacing="15"
                  alignment="CENTER"
                  styleClass="card">

                <padding>
                    <Insets top="20"
                            right="20"
                            bottom="20"
                            left="20"/>
                </padding>

                <Label text="HASIL PREDIKSI"
                       styleClass="subtitle"/>

                <Label fx:id="lblHasil"
                       text="-"
                       style="-fx-font-size:22px;
                              -fx-font-weight:bold;
                              -fx-text-fill:#2563eb;"/>

                <Label text="Probabilitas"
                       style="-fx-font-weight:bold;"/>

                <Label fx:id="lblProbabilitas"
                       text="-"
                       style="-fx-font-size:18px;"/>

            </VBox>

        </VBox>

    </center>

</BorderPane>