<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.PrediksiMLController"
            stylesheets="@style.css">

    <!-- ================= HEADER ================= -->

    <top>
        <VBox alignment="CENTER"
              spacing="8"
              styleClass="top-panel">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="PREDIKSI RISIKO DIABETES"
                   styleClass="title"/>

            <Label text="Masukkan data medis pasien untuk memprediksi risiko diabetes."
                   styleClass="subtitle"/>
        </VBox>
    </top>

    <!-- ================= CONTENT ================= -->

    <center>

        <VBox spacing="25"
              alignment="TOP_CENTER"
              fillWidth="true">

            <padding>
                <Insets top="25"
                        right="40"
                        bottom="25"
                        left="40"/>
            </padding>

            <!-- CARD INPUT -->

            <VBox spacing="25"
                  alignment="CENTER"
                  styleClass="card"
                  maxWidth="900">

                <padding>
                    <Insets top="25"
                            right="25"
                            bottom="25"
                            left="25"/>
                </padding>

                <GridPane alignment="CENTER"
                          hgap="20"
                          vgap="18">

                    <columnConstraints>
                        <ColumnConstraints prefWidth="180"/>
                        <ColumnConstraints prefWidth="220"/>
                        <ColumnConstraints prefWidth="180"/>
                        <ColumnConstraints prefWidth="220"/>
                    </columnConstraints>

                    <!-- BARIS 1 -->

                    <Label text="Kehamilan (Pregnancies)"/>
                    <TextField fx:id="txtPregnancies"
                               promptText="0"
                               GridPane.columnIndex="1"/>

                    <Label text="Glukosa (Glucose)"
                           GridPane.columnIndex="2"/>
                    <TextField fx:id="txtGlucose"
                               promptText="120"
                               GridPane.columnIndex="3"/>

                    <!-- BARIS 2 -->

                    <Label text="Tekanan Darah (mmHg)"
                           GridPane.rowIndex="1"/>
                    <TextField fx:id="txtBloodPressure"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="1"/>

                    <Label text="Ketebalan Kulit (mm)"
                           GridPane.columnIndex="2"
                           GridPane.rowIndex="1"/>
                    <TextField fx:id="txtSkinThickness"
                               promptText="20"
                               GridPane.columnIndex="3"
                               GridPane.rowIndex="1"/>

                    <!-- BARIS 3 -->

                    <Label text="Insulin (mU U/ml)"
                           GridPane.rowIndex="2"/>
                    <TextField fx:id="txtInsulin"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="2"/>

                    <Label text="BMI"
                           GridPane.columnIndex="2"
                           GridPane.rowIndex="2"/>
                    <TextField fx:id="txtBMI"
                               GridPane.columnIndex="3"
                               GridPane.rowIndex="2"/>

                    <!-- BARIS 4 -->

                    <Label text="Riwayat Keluarga (DPF)"
                           GridPane.rowIndex="3"/>
                    <TextField fx:id="txtDPF"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="3"/>

                    <Label text="Umur (Tahun)"
                           GridPane.columnIndex="2"
                           GridPane.rowIndex="3"/>
                    <TextField fx:id="txtAge"
                               GridPane.columnIndex="3"
                               GridPane.rowIndex="3"/>

                </GridPane>

                <!-- BUTTON -->

                <HBox spacing="18"
                      alignment="CENTER">

                    <Button text="🔍 Prediksi Sekarang"
                            onAction="#handlePrediksi"
                            styleClass="btn-save-modern"/>

                    <Button text="🔄 Reset"
                            onAction="#handleReset"
                            styleClass="btn-secondary"/>

                    <Button text="❌ Tutup"
                            onAction="#handleClose"
                            styleClass="btn-danger"/>

                </HBox>

            </VBox>

            <!-- HASIL -->

            <VBox spacing="12"
                  alignment="CENTER"
                  styleClass="card"
                  maxWidth="500">

                <padding>
                    <Insets top="20"
                            right="20"
                            bottom="20"
                            left="20"/>
                </padding>

                <Label text="HASIL PREDIKSI"
                       styleClass="subtitle"/>

                <Label fx:id="lblHasil"
                       text="-"
                       style="-fx-font-size:24px;
                              -fx-font-weight:bold;
                              -fx-text-fill:#16a34a;"/>

                <Label text="Probabilitas :"
                       style="-fx-font-weight:bold;"/>

                <Label fx:id="lblProbabilitas"
                       text="-"
                       style="-fx-font-size:18px;"/>

            </VBox>

        </VBox>

    </center>

</BorderPane>